    accessory: { icon: '🎒', name: 'Zubehör', color: '#27ae60' },
    craft: { icon: '🔨', name: 'Handwerk', color: '#d35400' },
    prop: { icon: '🎪', name: 'Requisite', color: '#8e44ad' },
