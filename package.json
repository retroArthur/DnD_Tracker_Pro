{
  "name": "dnd-tracker-modular",
  "version": "1.3.0",
  "type": "module",
  "description": "D&D Kampagnen-Tracker Pro - Modulare Version",
  "main": "loader.js",
  "scripts": {
    "analyze:render": "python3 tools/analyze-render.py",
    "analyze:handlers": "python3 tools/migrate-event-handlers.py",
    "split:render": "python3 tools/analyze-render.py --execute",
    "migrate:handlers": "python3 tools/migrate-event-handlers.py --execute",
    "build": "python3 build-optimized.py",
    "build:dev": "python3 build.py",
    "build:prod": "python3 build-production.py",
    "build:optimized": "python3 build-optimized.py",
    "build:python": "python3 build.py",
    "build:python:minify": "python3 build.py --minify",
    "build:webpack": "webpack --mode production --config tools/webpack.config.js",
    "build:webpack:dev": "webpack --mode development --config tools/webpack.config.js",
    "dev": "webpack serve --mode development --config tools/webpack.config.js",
    "serve": "python3 -m http.server 8000",
    "validate": "python3 validate.py",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "tsc": "tsc",
    "tsc:watch": "tsc --watch",
    "tsc:check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --max-warnings 50",
    "lint:all": "eslint . --max-warnings 100",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "format:all": "prettier --write .",
    "check": "npm run tsc:check && npm run lint && npm run format:check",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report tests/e2e/reports"
  },
  "keywords": [
    "dnd",
    "tracker",
    "rpg",
    "campaign"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prettier": "^3.7.4",
    "style-loader": "^3.3.3",
    "terser-webpack-plugin": "^5.3.9",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}