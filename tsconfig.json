{
    "compilerOptions": {
        // Basis-Einstellungen
        "target": "ES2020",
        "module": "ES2015",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "moduleResolution": "node",

        // JavaScript + Declaration mode
        "allowJs": true,
        "checkJs": false,

        // Output (declaration files only)
        "declaration": true,
        "declarationMap": false,
        "sourceMap": false,
        "emitDeclarationOnly": true,
        "outDir": ".",

        // Type checking (relaxed for .js)
        "strict": false,
        "noImplicitAny": false,

        // Interoperability
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,

        // Path aliases
        "baseUrl": ".",
        "paths": {
            "@core/*": ["core/*"],
            "@features/*": ["features/*"],
            "@ui/*": ["ui/*"],
            "@utils/*": ["utils/*"],
            "@types/*": ["types/*"],
            "@systems/*": ["systems/*"],
            "@render/*": ["render/*"]
        },

        // Types
        "types": [],
        "typeRoots": ["./types", "./node_modules/@types"]
    },

    "include": [
        "core/**/*.js",
        "features/**/*.js",
        "ui/**/*.js",
        "utils/**/*.js",
        "systems/**/*.js",
        "render/**/*.js",
        "types/**/*.d.ts"
    ],

    "exclude": ["node_modules", "dist", "tools", "tests", "*.py", "**/*.test.js"]
}
